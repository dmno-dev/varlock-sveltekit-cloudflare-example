{
  "name": "sveltekit-varlock-example",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "dev:cf": "SVELTE_ADAPTER=cloudflare vite dev",
    "build:cf": "SVELTE_ADAPTER=cloudflare vite build",
    "preview:cf": "SVELTE_ADAPTER=cloudflare vite preview",
    "deploy:cf": "SVELTE_ADAPTER=cloudflare varlock-wrangler deploy",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "dependencies": {
    "varlock": "link:../../../varlock/packages/varlock"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.39.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.48.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^24",
    "@varlock/cloudflare-integration": "https://pkg.pr.new/@varlock/cloudflare-integration@622",
    "@varlock/vite-integration": "0.2.10",
    "@vitest/browser-playwright": "^4.0.10",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.0",
    "globals": "^16.5.0",
    "playwright": "^1.56.1",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vite": "^7.2.2",
    "vitest": "^4.0.10",
    "vitest-browser-svelte": "^2.0.1",
    "wrangler": "^4.83.0"
  }
}
